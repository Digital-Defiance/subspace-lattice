{
  "name": "@subspace-lattice/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "test:e2e": "nx run web-e2e:e2e",
    "test:rules": "firebase emulators:exec --only firestore --project demo-subspace \"yarn nx test functions -- firestore.rules.spec.ts\"",
    "sim": "nx run core:sim",
    "calibrate:ai": "nx run core:calibrate-ai",
    "evolve": "nx run core:evolve",
    "build:rules": "bash scripts/build-rules.sh",
    "sync:docs-public": "bash scripts/sync-docs-public.sh",
    "deploy:firebase": "bash scripts/deploy-firebase.sh",
    "deploy:firebase:hosting": "bash scripts/deploy-firebase.sh hosting:lattice",
    "deploy:firebase:functions": "bash scripts/deploy-firebase.sh functions:lattice",
    "ensure:functions-invoker": "bash scripts/ensure-functions-public-invoker.sh",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "serve:web": "nx serve web",
    "serve:desktop": "nx run desktop:tauri-dev",
    "init:desktop": "bash scripts/init-desktop.sh",
    "tauri:dev": "nx run desktop:tauri-dev",
    "tauri:build": "nx run desktop:tauri-build",
    "tauri:icon": "bash scripts/tauri-icon.sh",
    "tauri:ios:dev": "bash scripts/ensure-tauri-cli-links.sh && cd apps/desktop && yarn tauri ios dev",
    "tauri:ios:build": "bash scripts/ensure-tauri-cli-links.sh && cd apps/desktop && yarn tauri ios build",
    "tauri:ios:build:appstore": "bash scripts/build-ios-appstore.sh",
    "tauri:android:dev": "bash scripts/ensure-tauri-cli-links.sh && cd apps/desktop && yarn tauri android dev",
    "tauri:android:build": "bash scripts/inject-android-manifest.sh && bash scripts/ensure-tauri-cli-links.sh && cd apps/desktop && yarn tauri android build",
    "sync:ios-icons": "bash scripts/sync-ios-icons.sh",
    "sync:android-icons": "bash scripts/sync-android-icons.sh",
    "sync:windows-msix-assets": "node apps/desktop/scripts/sync-windows-msix-assets.mjs",
    "ensure:tauri-cli-links": "bash scripts/ensure-tauri-cli-links.sh",
    "app:version": "node scripts/app-version.mjs",
    "build:all": "nx run-many -t build",
    "build:all:native": "bash scripts/build-all.sh",
    "build:mac": "bash scripts/build-macos.sh",
    "build:mac-appstore": "bash scripts/build-macos-appstore.sh",
    "build:macos-appstore": "bash scripts/build-macos-appstore.sh",
    "build:ios-appstore": "bash scripts/build-ios-appstore.sh",
    "build:android": "bash scripts/build-android.sh",
    "build:android:apk": "bash scripts/build-android.sh --apk",
    "build:windows": "cd apps/desktop && yarn tauri build --target x86_64-pc-windows-msvc",
    "build:windows:store": "yarn workspace @subspace-lattice/desktop tauri:windows:build",
    "build:windows:cross": "bash scripts/build-windows-crosscompile.sh",
    "update:cask": "bash scripts/update-subspace-lattice-cask.sh",
    "inject:android-manifest": "bash scripts/inject-android-manifest.sh",
    "inject:ios-signing": "bash scripts/inject-ios-signing.sh",
    "emulators": "firebase emulators:start --import=./.firebase-emulator-data --export-on-exit",
    "functions:build": "nx build functions",
    "auth:firebase": "firebase login --reauth",
    "auth:gcloud": "gcloud auth login && gcloud config set project warp-12",
    "auth:npm": "npm login --registry registry.npmjs.org",
    "auth:all": "yarn auth:firebase && yarn auth:gcloud && yarn auth:npm"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@nx/eslint": "23.1.0",
    "@nx/eslint-plugin": "23.1.0",
    "@nx/js": "23.1.0",
    "@nx/react": "23.1.0",
    "@nx/vite": "23.1.0",
    "@nx/vitest": "23.1.0",
    "@playwright/test": "^1.61.1",
    "@swc/helpers": "~0.5.18",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "firebase-tools": "^15.24.0",
    "jsdom": "^29.1.1",
    "nx": "23.1.0",
    "prettier": "~3.6.2",
    "sass-embedded": "^1.100.0",
    "tslib": "^2.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "yarn@4.17.0",
  "dependencies": {
    "firebase": "^12.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  }
}
