# Root / deploy env (optional). Process ENV wins over these files.
# Client Vite keys live in apps/web/.env — see apps/web/.env.example.

# Shared Interstellar Warp Gaming Federation Firebase project (with Warp).
FIREBASE_PROJECT=warp-12

# Optional Tauri overrides (scripts/tauri-config-from-env.mjs → tauri.conf.local.json)
TAURI_PRODUCT_NAME=Subspace Lattice
TAURI_IDENTIFIER=org.digitaldefiance.app.subspacelattice
APPLE_BUNDLE_ID=org.digitaldefiance.app.subspacelattice
APPLE_PRODUCT_NAME=Subspace Lattice

# GitHub release + Homebrew (digital-defiance/homebrew-tap)
GITHUB_REPO=Digital-Defiance/subspace-lattice
HOMEBREW_TAP_DIR=/Volumes/Code/homebrew-tap
# HOMEBREW_CASK_PATH=   # default $HOMEBREW_TAP_DIR/Casks/subspace-lattice.rb
# LATTICE_PUSH_HOMEBREW_TAP=0

# Apple signing (required for App Store / notarized builds)
# APPLE_TEAM_ID=
# APPLE_PUBLISHER_NAME=Digital Defiance
# APPLE_SIGNING_IDENTITY=Developer ID Application: …
# APPLE_IOS_SIGN_IDENTITY=Apple Distribution: … (TEAM_ID)

# iOS App Store (paths relative to repo root or absolute)
# APPLE_IOS_PROVISIONING_PROFILE=apps/desktop/src-tauri/SubspaceLattice_iOS.mobileprovision
# APPLE_IOS_CERTIFICATE=apps/desktop/src-tauri/SubspaceLattice_iOS.p12
# APPLE_IOS_CERTIFICATE_PASSWORD=

# Mac App Store
# APPLE_PROVISIONING_PROFILE=apps/desktop/src-tauri/SubspaceLattice.provisionprofile

# App Store Connect API (upload only — unset during local tauri build for iOS)
# APPLE_API_KEY=
# APPLE_API_ISSUER=
# APPLE_API_KEY_DIR=$HOME/private_keys
# APPLE_API_KEY_PATH=

# Android Play upload keystore
# ANDROID_KEYSTORE=apps/desktop/src-tauri/SubspaceLattice_upload.jks
# ANDROID_KEY_ALIAS=upload
# ANDROID_KEYSTORE_PASSWORD=

# Optional Google OAuth deep links (mobile)
# VITE_GOOGLE_IOS_CLIENT_ID=
# VITE_GOOGLE_ANDROID_CLIENT_ID=
# VITE_GOOGLE_DESKTOP_CLIENT_ID=
# VITE_GOOGLE_OAUTH_REDIRECT_SCHEME=
# VITE_GOOGLE_OAUTH_REDIRECT_SCHEME_ANDROID=
