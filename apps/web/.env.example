VITE_FIREBASE_PROJECT_ID=warp-12
VITE_FIREBASE_AUTH_DOMAIN=warp-12.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=warp-12.firebasestorage.app
# From Firebase Console > Project settings > Your apps (shared IWGF / Warp project)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Production builds never use emulators. For local emulators set
# VITE_USE_FIREBASE_EMULATORS=true in .env.local (must be explicit — DEV alone
# does not enable them). Do not leave this true in .env if you deploy from here.
VITE_USE_FIREBASE_EMULATORS=false
