{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Subspace Lattice",
  "version": "0.1.7",
  "identifier": "org.digitaldefiance.app.subspacelattice",
  "mainBinaryName": "SubspaceLattice",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": {
      "script": "yarn nx serve web",
      "cwd": "../.."
    },
    "beforeBuildCommand": {
      "script": "yarn nx build web",
      "cwd": "../.."
    }
  },
  "app": {
    "windows": [
      {
        "title": "Subspace Lattice",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "public.app-category.games",
    "shortDescription": "Federation-themed Chess + Go — command the fleet, control the lattice.",
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "hardenedRuntime": true
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "versionCode": 7
    },
    "iOS": {
      "bundleVersion": "7"
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": []
    }
  }
}
